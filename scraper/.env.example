GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RESEND_API_KEY=your_resend_api_key_here
VERCEL_TOKEN=your_vercel_token_here
FROM_EMAIL=charles@yourdomain.com

# Durable state (optional). When both are set, the store uses Supabase
# instead of the local SQLite data/businesses.db — required for the scrape
# cron to persist across GitHub Actions runs. Run supabase/schema.sql first.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
